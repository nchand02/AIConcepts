    A[Input Tokens] --> B[Input Embeddings]
    B --> C[Positional Encoding]
    C --> D[Encoder Stack<br/>N × layers]
    D --> E[Decoder Stack<br/>N × layers]
    E --> F[Linear + Softmax]
    F --> G[Output Probabilities]
    
    %% Semantic color classes
    classDef input fill:#dbeafe,stroke:#3b82f6,stroke-width:2px,color:#1e293b
    classDef process fill:#fef3c7,stroke:#f59e0b,stroke-width:2px,color:#1e293b
